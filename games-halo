  <footer>© 2026 — Cairo Yepez · Chicago, IL · All rights reserved · A tribute to fallen heroes of the era.</footer>

  <script>
    document.querySelectorAll('.game-card').forEach(card => {
      const inner = card.querySelector('.game-card-inner');
      card.addEventListener('mousemove', e => {
        const r = card.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top - r.height / 2;
        inner.style.transform = `rotateX(${-(y/r.height)*18}deg) rotateY(${(x/r.width)*18}deg) scale(1.04)`;
      });
      card.addEventListener('mouseleave', () => { inner.style.transition = 'transform .4s ease'; inner.style.transform = 'rotateX(0) rotateY(0) scale(1)'; });
      card.addEventListener('mouseenter', () => { inner.style.transition = 'transform .1s ease'; });
    });
  </script>

