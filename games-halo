<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Halo — Games — Cairo Yepez</title>
  <link rel="stylesheet" href="style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--cream); color: var(--ink); font-family: 'EB Garamond', Georgia, serif; }
    body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 999; opacity: .5; }
    .masthead { background: var(--maroon); color: var(--cream); text-align: center; padding: 10px 20px 8px; border-bottom: 3px double var(--olive); }
    .masthead .site-name { font-family: 'Special Elite', cursive; font-size: 2.2rem; letter-spacing: .08em; color: var(--cream); text-decoration: none; }
    .masthead .tagline { font-family: 'Share Tech Mono', monospace; font-size: .7rem; color: var(--blue-margin-light); letter-spacing: .15em; margin-top: 2px; }
    .page-wrap { max-width: 1100px; margin: 0 auto; padding: 30px 20px 60px; display: grid; grid-template-columns: 200px 1fr; gap: 30px; }
    .sidebar-label { font-family: 'Share Tech Mono', monospace; font-size: .62rem; letter-spacing: .18em; text-transform: uppercase; color: var(--maroon); border-bottom: 1px solid var(--maroon); padding-bottom: 4px; margin-bottom: 10px; }
    .sidebar nav a { display: block; font-family: 'Special Elite', cursive; font-size: .88rem; color: var(--ink); text-decoration: none; padding: 4px 0; border-bottom: 1px dotted var(--cream-dark); transition: color .2s; }
    .sidebar nav a:hover, .sidebar nav a.active { color: var(--maroon); }
    .page-header { margin-bottom: 28px; border-bottom: 2px solid var(--maroon); padding-bottom: 16px; }
    .page-header .breadcrumb { font-family: 'Share Tech Mono', monospace; font-size: .6rem; letter-spacing: .15em; color: var(--olive); margin-bottom: 8px; }
    .page-header .breadcrumb a { color: var(--olive); text-decoration: none; }
    .page-header h1 { font-family: 'Special Elite', cursive; font-size: 2.4rem; color: var(--maroon); line-height: 1; }
    .page-header .subtitle { font-style: italic; font-size: .95rem; color: #5a4f45; margin-top: 6px; }
    .section-divider { font-family: 'Share Tech Mono', monospace; font-size: .65rem; letter-spacing: .2em; text-transform: uppercase; color: var(--maroon); border-top: 1px solid var(--cream-dark); padding-top: 18px; margin: 28px 0 18px; }
    .game-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 20px; margin-bottom: 30px; }
    .game-card { perspective: 800px; }
    .game-card-inner { display: flex; flex-direction: column; transition: transform .1s ease; transform-style: preserve-3d; }
    .cover-wrap { width: 100%; aspect-ratio: 3/4; background: var(--cream-dark); border: 1.5px solid var(--maroon); overflow: hidden; position: relative; box-shadow: 3px 3px 0 var(--olive-light); }
    .cover-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: 'Share Tech Mono', monospace; font-size: .55rem; color: var(--olive); text-align: center; padding: 8px; background: linear-gradient(135deg, var(--cream-dark) 0%, #d4c9b0 100%); }
    .cover-caption { font-family: 'Share Tech Mono', monospace; font-size: .58rem; color: var(--olive-light); margin-top: 6px; padding: 0 2px; line-height: 1.4; }
    .game-title { font-family: 'Special Elite', cursive; font-size: .88rem; color: var(--ink); margin-top: 5px; line-height: 1.3; }
    .game-year { font-family: 'Share Tech Mono', monospace; font-size: .6rem; color: var(--olive); }
    .star-rating { margin-top: 4px; font-size: .8rem; color: var(--maroon); letter-spacing: 1px; }
    .game-blurb { font-size: .8rem; font-style: italic; color: #5a4f45; line-height: 1.5; margin-top: 5px; }

    /* FEATURED GAME BANNER */
    .featured-banner {
      background: var(--paper);
      border: 1.5px solid var(--maroon);
      border-left: 5px solid var(--maroon);
      padding: 20px;
      margin-bottom: 28px;
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 20px;
      box-shadow: 4px 4px 0 var(--olive-light);
    }
    .featured-banner .feat-cover {
      aspect-ratio: 3/4;
      background: var(--cream-dark);
      border: 1.5px solid var(--maroon);
      overflow: hidden;
    }
    .featured-banner .feat-cover img { width: 100%; height: 100%; object-fit: cover; }
    .featured-banner .feat-cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: 'Share Tech Mono', monospace; font-size: .55rem; color: var(--olive); text-align: center; padding: 8px; background: linear-gradient(135deg, #2a3a4a, #1a2a3a); color: #8ab4d4; }
    .featured-banner .feat-label { font-family: 'Share Tech Mono', monospace; font-size: .6rem; letter-spacing: .18em; color: var(--olive); margin-bottom: 6px; }
    .featured-banner h2 { font-family: 'Special Elite', cursive; font-size: 1.6rem; color: var(--maroon); margin-bottom: 8px; }
    .featured-banner p { font-size: .9rem; line-height: 1.65; color: #3a2f25; }
    .featured-banner .feat-rating { font-size: 1rem; color: var(--maroon); margin-top: 10px; }

    footer { background: var(--maroon); color: var(--cream); text-align: center; padding: 14px 20px; font-family: 'Share Tech Mono', monospace; font-size: .65rem; letter-spacing: .1em; border-top: 3px double var(--olive); }
    @media (max-width: 700px) { .page-wrap { grid-template-columns: 1fr; } .featured-banner { grid-template-columns: 1fr; } }
  </style>
